{
   "name": "react-motion-modal-monorepo",
   "private": true,
   "scripts": {
      "dev": "turbo run dev",
      "dev:document": "yarn workspace document dev",
      "dev:example": "yarn workspace example dev",
      "prepare": "husky",
      "format": "biome format --write .",
      "lint": "biome lint ."
   },
   "lint-staged": {
      "*.{ts,tsx,json}": "biome check --write --no-errors-on-unmatched"
   },
   "devDependencies": {
      "@biomejs/biome": "2.5.1",
      "husky": "^9.1.7",
      "lint-staged": "^15",
      "turbo": "^2.9.16",
      "typescript": "5.9.2"
   },
   "engines": {
      "node": ">=18"
   },
   "packageManager": "yarn@1.22.22",
   "workspaces": [
      "apps/*",
      "packages/*"
   ]
}
