{
   "name": "react-motion-modal-monorepo",
   "private": true,
   "scripts": {
      "build": "turbo run build",
      "dev": "turbo run dev",
      "dev:document": "yarn workspace document dev",
      "check-types": "turbo run check-types",
      "lint": "turbo run lint",
      "format": "biome format --write .",
      "lint:root": "biome lint ."
   },
   "devDependencies": {
      "@biomejs/biome": "2.2.0",
      "turbo": "^2.9.16",
      "typescript": "5.9.2"
   },
   "engines": {
      "node": ">=18"
   },
   "packageManager": "yarn@1.22.22",
   "workspaces": [
      "apps/*",
      "packages/*"
   ]
}
