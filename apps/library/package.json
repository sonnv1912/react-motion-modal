{
   "name": "react-motion-modal",
   "version": "1.3.2",
   "type": "module",
   "sideEffects": [
      "**/*.css"
   ],
   "license": "MIT",
   "main": "./dist/index.js",
   "module": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "author": "Ngô Văn Sơn",
   "homepage": "https://sonnv1912.github.io/react-motion-modal/",
   "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610",
   "files": [
      "dist"
   ],
   "keywords": [
      "react",
      "modal",
      "animated",
      "framer-motion",
      "react-modal"
   ],
   "repository": {
      "type": "git",
      "url": "git+https://github.com/sonnv1912/react-motion-modal.git"
   },
   "bugs": {
      "url": "https://github.com/sonnv1912/react-motion-modal/issues"
   },
   "engines": {
      "node": ">=18.0.0"
   },
   "publishConfig": {
      "access": "public",
      "registry": "https://registry.npmjs.org/"
   },
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js"
      },
      "./style.css": "./dist/index.css",
      "./main.css": "./dist/index.css"
   },
   "scripts": {
      "dev": "vite",
      "build": "tsc -b && vite build",
      "ci": "yarn build",
      "check-types": "tsc -b --pretty false",
      "test": "vitest run",
      "test:watch": "vitest",
      "preview": "vite preview",
      "bump:patch": "yarn version --patch --no-git-tag-version",
      "bump:minor": "yarn version --minor --no-git-tag-version",
      "bump:major": "yarn version --major --no-git-tag-version",
      "release:check": "yarn build && npm pack --dry-run"
   },
   "dependencies": {},
   "devDependencies": {
      "@types/node": "^24.0.12",
      "@types/react": "^19.1.8",
      "@types/react-dom": "^19.1.6",
      "@vitejs/plugin-react": "^4.6.0",
      "@vitest/browser": "3.2.4",
      "@vitest/coverage-v8": "3.2.4",
      "globals": "^16.3.0",
      "motion": "^12.23.12",
      "playwright": "^1.53.2",
      "react": "^19.1.0",
      "react-dom": "^19.2.7",
      "typescript": "~5.8.3",
      "vite": "^7.0.3",
      "vite-plugin-dts": "^4.5.4",
      "vitest": "3.2.4",
      "zustand": "^5.0.7"
   },
   "peerDependencies": {
      "motion": ">12.0.0",
      "react": ">=18.0.0",
      "react-dom": ">=18.0.0",
      "zustand": ">=5.0.0"
   }
}
